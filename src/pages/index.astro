---
// Fully static page. All flight logic runs client-side against two keyless,
// CORS-enabled public APIs (airplanes.live + adsbdb.com). No backend.
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="description" content="Live green radar of aircraft flying near you." />
    <meta name="theme-color" content="#020a05" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="Flight Radar" />
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/favicon.svg`} />
    <link rel="apple-touch-icon" href={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/apple-touch-icon.png`} />
    <title>Nearby Flight Radar</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Share+Tech+Mono&display=swap"
    />
  </head>
  <body>
    <div class="corner-controls corner-left">
      <button
        id="passport-btn"
        type="button"
        class="fs-btn passport-btn"
        title="Flight passport"
        aria-label="Open flight passport"
        aria-haspopup="dialog"
      >
        <svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true" focusable="false">
          <circle cx="12" cy="12" r="9" fill="none" stroke="currentColor" stroke-width="2" />
          <ellipse cx="12" cy="12" rx="4" ry="9" fill="none" stroke="currentColor" stroke-width="2" />
          <path d="M3.5 9h17M3.5 15h17" fill="none" stroke="currentColor" stroke-width="2" />
        </svg>
        <span class="passport-btn-label">Passport</span>
      </button>

      <button
        id="dev-toggle"
        type="button"
        class="fs-btn dev-toggle"
        title="Dev toolbox"
        aria-label="Open dev toolbox"
        aria-haspopup="dialog"
      >
        <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" focusable="false">
          <path
            d="M9 8l-4 4 4 4M15 8l4 4-4 4"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          />
        </svg>
      </button>
    </div>

    <button
      id="compass-btn"
      type="button"
      class="fs-btn compass-btn"
      title="Orient radar to compass"
      aria-label="Toggle compass orientation"
      aria-pressed="false"
      hidden
    >
      <svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true" focusable="false">
        <circle
          cx="12"
          cy="12"
          r="10"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
        />
        <path
          class="compass-needle-stroke"
          d="m16.24 7.76-1.804 5.411a2 2 0 0 1-1.265 1.265L7.76 16.24l1.804-5.411a2 2 0 0 1 1.265-1.265z"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        />
        <path
          class="compass-needle-fill"
          d="m16.24 7.76-1.804 5.411a2 2 0 0 1-1.265 1.265L7.76 16.24l1.804-5.411a2 2 0 0 1 1.265-1.265z"
          fill="currentColor"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        />
      </svg>
    </button>

    <button
      id="sound-btn"
      type="button"
      class="fs-btn sound-btn"
      title="Enable sound"
      aria-label="Toggle sound"
      aria-pressed="false"
    >
      <svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true" focusable="false">
        <path
          d="M4 9v6h4l5 4V5L8 9H4z"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linejoin="round"
        />
        <path
          class="snd-icon-on"
          d="M16 8.5a5 5 0 0 1 0 7M18.5 6a8 8 0 0 1 0 12"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
        />
        <path
          class="snd-icon-off"
          d="M16 9l5 6M21 9l-5 6"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
        />
      </svg>
    </button>

    <button
      id="fullscreen-btn"
      type="button"
      class="fs-btn"
      title="Fullscreen"
      aria-label="Toggle fullscreen"
      aria-pressed="false"
    >
      <svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true" focusable="false">
        <path
          class="fs-icon-expand"
          d="M4 9V4h5M20 9V4h-5M4 15v5h5M20 15v5h-5"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        />
        <path
          class="fs-icon-collapse"
          d="M9 4v5H4M15 4v5h5M9 20v-5H4M15 20v-5h5"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        />
      </svg>
    </button>

    <main class="app">
      <header class="hud">
        <h1>NEARBY FLIGHT RADAR</h1>
        <dl class="readout">
          <div>
            <dt>CENTER</dt>
            <dd class="range-cell">
              <span id="stat-location">&mdash;</span>
              <button
                id="center-locate"
                type="button"
                class="range-edit"
                title="Center on your current location"
                aria-label="Center on your current location"
              >
                Locate
              </button>
              <button id="center-edit" type="button" class="range-edit" aria-haspopup="dialog">Set</button>
            </dd>
          </div>
          <div>
            <dt>RANGE</dt>
            <dd class="range-cell">
              <span id="stat-range">&mdash;</span>
              <button id="range-edit" type="button" class="range-edit" aria-haspopup="dialog">Adjust</button>
            </dd>
          </div>
        </dl>
      </header>

      <section class="scope">
        <div class="crt-wrap">
          <div class="crt">
            <canvas
              id="radar"
              width="720"
              height="720"
              role="img"
              aria-label="Flight radar scope. A text list of the aircraft currently detected follows below."
            ></canvas>
            <div class="crt-roll" aria-hidden="true"></div>
          </div>
          <!-- Info cards render here, above the circular CRT mask and its
               scanline/glare overlays, so they are never clipped or dimmed. -->
          <canvas id="radar-labels" class="label-layer" width="720" height="720" aria-hidden="true"></canvas>
          <!-- Live "badge earned" toasts. Perch at the top edge of the scope so
               they celebrate an unlock without covering the sweep, then fade out
               on their own. Populated by main.js. -->
          <div id="badge-toasts" class="badge-toasts" aria-live="polite" aria-atomic="false"></div>
          <!-- Focus-mode banner. Shown while a single contact is locked on;
               gives an obvious way to leave focus mode. Wired in main.js. -->
          <div id="focus-bar" class="focus-bar" hidden>
            <div id="focus-photo" class="focus-photo" hidden></div>
            <div class="focus-info">
              <div class="focus-head">
                <span id="focus-title" class="focus-title"></span>
                <span id="focus-sub" class="focus-sub"></span>
              </div>
              <div id="focus-stats" class="focus-stats"></div>
            </div>
            <button id="focus-exit" type="button" class="focus-exit" aria-label="Exit focus mode">
              <span aria-hidden="true">&times;</span> Exit
            </button>
          </div>
        </div>
      </section>

      <!-- Dev / demo panel. Hidden unless the page is loaded with ?dev in the
           URL (or the D key is pressed). Injects synthetic contacts so the
           banner and highlighting can be previewed with no real traffic.
           Wired up in main.js. -->
      <div id="dev-panel" class="dev-panel" hidden>
        <div class="dev-head">
          <span>DEV / DEMO</span>
          <button id="dev-close" type="button" class="icon-btn" aria-label="Hide dev panel">&times;</button>
        </div>
        <div class="dev-buttons">
          <button type="button" data-demo="heavy">Heavy jet</button>
          <button type="button" data-demo="rare">Rare (A380)</button>
          <button type="button" data-demo="military">Military</button>
          <button type="button" data-demo="emergency">Emergency 7700</button>
          <button type="button" data-demo="radio">Radio fail 7600</button>
          <button type="button" data-demo="hijack">Hijack 7500</button>
          <button type="button" data-demo="light">Light GA</button>
          <button type="button" data-demo="helicopter">Helicopter</button>
        </div>
        <div class="dev-buttons">
          <button type="button" data-demo-action="clear">Clear demo</button>
        </div>
        <p class="dev-hint">Open with <code>?dev</code> or toggle with <kbd>D</kbd>.</p>
      </div>

      <footer class="hud">
        <p id="status" data-kind="info" role="status" aria-live="polite">Initializing&hellip;</p>
        <p class="credit">
          Positions: airplanes.live &middot; Routes: adsbdb.com &middot; Map: OpenStreetMap &middot; Non-commercial use
        </p>
      </footer>

      <!-- Screen-reader accessibility. The radar is drawn on a <canvas>, which is
           opaque to assistive tech, so these regions provide an equivalent text
           experience: `sr-live` is a polite log that announces each aircraft the
           moment it appears on the scope, and `sr-aircraft` is a navigable list
           that always mirrors the contacts currently being tracked. Both are
           visually hidden but exposed to screen readers. -->
      <div id="sr-live" class="sr-only" role="log" aria-live="polite" aria-atomic="false"></div>
      <section id="sr-aircraft" class="sr-only" aria-labelledby="sr-aircraft-heading">
        <h2 id="sr-aircraft-heading">Aircraft on radar</h2>
        <p id="sr-aircraft-empty">No aircraft on the radar right now.</p>
        <ul id="sr-aircraft-list"></ul>
      </section>
    </main>

    <div id="range-modal" class="modal" role="dialog" aria-modal="true" aria-label="Set radar range" hidden>
      <div class="modal-card">
        <div class="modal-head">
          <span>SET RADAR RANGE</span>
          <button id="range-close" type="button" class="icon-btn" aria-label="Close">&times;</button>
        </div>
        <div id="range-map" class="map"></div>
        <div class="modal-controls">
          <input id="range-slider" type="range" min="1" max="50" step="1" value="5" aria-label="Radius in nautical miles" />
          <output id="range-value">5 nm</output>
          <button id="range-apply" type="button" class="range-apply">Apply</button>
        </div>
        <p class="modal-hint">Drag the slider or click the map to set your radius.</p>
      </div>
    </div>

    <div id="center-modal" class="modal" role="dialog" aria-modal="true" aria-label="Set your location" hidden>
      <div class="modal-card">
        <div class="modal-head">
          <span>SET LOCATION</span>
          <button id="center-close" type="button" class="icon-btn" aria-label="Close">&times;</button>
        </div>
        <div id="center-map" class="map"></div>
        <div class="modal-controls">
          <input
            id="center-search"
            type="text"
            class="center-search"
            placeholder="Search a place, or enter lat, lon"
            aria-label="Search for a location"
            autocomplete="off"
          />
          <button id="center-search-btn" type="button" class="range-apply">Search</button>
        </div>
        <div class="modal-controls">
          <button id="center-geo" type="button" class="geo-btn">
            <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" focusable="false">
              <circle cx="12" cy="12" r="4" fill="none" stroke="currentColor" stroke-width="2" />
              <circle cx="12" cy="12" r="1.5" fill="currentColor" />
              <path
                d="M12 2v3M12 19v3M2 12h3M19 12h3"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
              />
            </svg>
            <span>Use my location</span>
          </button>
        </div>
        <div class="modal-controls">
          <output id="center-value">&mdash;</output>
          <button id="center-apply" type="button" class="range-apply">Apply</button>
        </div>
        <p id="center-hint" class="modal-hint">Search, or click the map to set your center.</p>
      </div>
    </div>

    <div id="passport-modal" class="modal" role="dialog" aria-modal="true" aria-label="Flight passport" hidden>
      <div class="modal-card passport-card">
        <div class="modal-head">
          <div class="modal-title">
            <span>FLIGHT PASSPORT</span>
            <span id="passport-opened" class="passport-opened"></span>
          </div>
          <div class="modal-head-actions">
            <button id="passport-share" type="button" class="passport-reset passport-share">Share card</button>
            <button id="passport-reset" type="button" class="passport-reset">Reset</button>
            <button id="passport-close" type="button" class="icon-btn" aria-label="Close">&times;</button>
          </div>
        </div>

        <div id="passport-tabs" class="passport-tabs" role="tablist" aria-label="Passport sections">
          <button type="button" class="passport-tab is-active" data-tab="countries" role="tab" aria-selected="true">Countries</button>
          <button type="button" class="passport-tab" data-tab="routes" role="tab" aria-selected="false">Routes</button>
          <button type="button" class="passport-tab" data-tab="aircraft" role="tab" aria-selected="false">Aircraft</button>
          <button type="button" class="passport-tab" data-tab="airlines" role="tab" aria-selected="false">Airlines</button>
          <button type="button" class="passport-tab" data-tab="badges" role="tab" aria-selected="false">Badges</button>
          <button type="button" class="passport-tab" data-tab="stats" role="tab" aria-selected="false">Session</button>
        </div>

        <div id="passport-body" class="passport-body">
          <!-- Countries: world map of destinations + country chips. -->
          <section id="tab-countries" class="passport-panel" role="tabpanel">
            <p class="modal-hint modal-hint-sticky">Countries glow brighter the more flights you've seen heading there. Click a chip to see its inbound flights.</p>
            <div class="passport-crt">
              <div id="passport-map" class="map passport-map"></div>
            </div>
            <div id="passport-list" class="passport-list"></div>
            <div id="passport-country-detail" class="country-detail"></div>
          </section>

          <!-- Routes: origin → destination pairings. -->
          <section id="tab-routes" class="passport-panel" role="tabpanel" hidden>
            <p class="modal-hint modal-hint-sticky">Origin &rarr; destination pairings from flights that crossed your radar. Click a route to see its flights.</p>
            <div id="routes-list" class="passport-list"></div>
            <div id="routes-detail" class="country-detail"></div>
          </section>

          <!-- Aircraft spotting logbook, grouped by type. -->
          <section id="tab-aircraft" class="passport-panel" role="tabpanel" hidden>
            <table class="log-table">
              <thead id="aircraft-head"></thead>
              <tbody id="aircraft-body"></tbody>
            </table>
          </section>

          <!-- Airlines spotting logbook. -->
          <section id="tab-airlines" class="passport-panel" role="tabpanel" hidden>
            <table class="log-table">
              <thead>
                <tr><th>Logo</th><th>Airline / operator</th><th>First seen</th><th class="log-count">Seen</th></tr>
              </thead>
              <tbody id="airlines-body"></tbody>
            </table>
          </section>

          <!-- Achievements / badges. -->
          <section id="tab-badges" class="passport-panel" role="tabpanel" hidden>
            <div id="badges-grid" class="badges-grid"></div>
          </section>

          <!-- Session / day stats. -->
          <section id="tab-stats" class="passport-panel" role="tabpanel" hidden>
            <div id="stats-body" class="stats-body"></div>
            <p class="modal-hint">Session figures reset when you reload; your countries, logbooks and badges are saved.</p>
          </section>
        </div>
      </div>
    </div>

    <!-- Shareable passport card: a client-side canvas snapshot of this session's
         stats, rendered on demand into an <img> for preview + download/share. -->
    <div id="passport-share-modal" class="modal" role="dialog" aria-modal="true" aria-label="Shareable passport card" hidden>
      <div class="modal-card share-card">
        <div class="modal-head">
          <span>SHARE PASSPORT</span>
          <div class="modal-head-actions">
            <button id="passport-share-close" type="button" class="icon-btn" aria-label="Close">&times;</button>
          </div>
        </div>
        <div class="share-body">
          <div class="share-preview">
            <img id="passport-share-img" alt="Your flight passport session summary card" />
          </div>
          <div class="share-actions">
            <button id="passport-share-native" type="button" class="range-apply share-native" hidden>Share&hellip;</button>
            <button id="passport-share-download" type="button" class="range-apply">Download PNG</button>
          </div>
          <p class="modal-hint share-hint">Your all-time passport with every country, aircraft, airline and badge you&rsquo;ve collected. </p>
        </div>
      </div>
    </div>

    <!-- Expanded aircraft photo (Planespotters). Sits above the passport modal;
         the photographer credit + link back are required by the API terms. -->
    <div id="photo-lightbox" class="photo-lightbox" role="dialog" aria-modal="true" aria-label="Aircraft photo" hidden>
      <figure class="photo-lightbox-figure">
        <button id="photo-lightbox-close" type="button" class="icon-btn photo-lightbox-close" aria-label="Close">&times;</button>
        <span id="photo-lightbox-title" class="photo-lightbox-title"></span>
        <img id="photo-lightbox-img" class="photo-lightbox-img" src="" alt="" />
        <figcaption id="photo-lightbox-credit" class="photo-lightbox-credit"></figcaption>
      </figure>
    </div>

    <script>
      import '../scripts/main.js';
    </script>

    <style is:global>
      :root {
        --green: #00ff78;
        --green-dim: rgba(0, 255, 120, 0.55);
        --bg: #020a05;
      }
      * { box-sizing: border-box; }
      /* Visually hidden but available to screen readers (the standard clip
         pattern). Used for the live announcements and the text aircraft list. */
      .sr-only {
        position: absolute;
        width: 1px;
        height: 1px;
        padding: 0;
        margin: -1px;
        overflow: hidden;
        clip: rect(0, 0, 0, 0);
        white-space: nowrap;
        border: 0;
      }
      html {
        /* Solid fill first so the iOS status-bar / notch area stays dark under
           apple-mobile-web-app-status-bar-style=black-translucent. */
        background-color: var(--bg);
        color-scheme: dark;
      }
      html, body {
        margin: 0;
        min-height: 100%;
        min-height: 100dvh;
        background-color: var(--bg);
        background-image: radial-gradient(circle at 50% 40%, #04170c 0%, var(--bg) 70%);
        color: var(--green);
        font-family: 'Share Tech Mono', ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
      }
      .app {
        min-height: 100%;
        min-height: 100dvh;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 12px;
        padding: 16px;
        padding-top: max(16px, env(safe-area-inset-top, 0px));
        padding-right: max(16px, env(safe-area-inset-right, 0px));
        padding-bottom: max(16px, env(safe-area-inset-bottom, 0px));
        padding-left: max(16px, env(safe-area-inset-left, 0px));
      }
      .hud { width: 100%; max-width: 760px; }
      h1 {
        font-size: clamp(14px, 3.5vw, 22px);
        letter-spacing: 0.25em;
        margin: 0 0 10px;
        text-shadow: 0 0 12px rgba(0, 255, 120, 0.6);
      }
      .readout {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 8px;
        margin: 0;
      }
      .readout > div {
        min-width: 0;
        border: 1px solid rgba(0, 255, 120, 0.25);
        border-radius: 6px;
        padding: 6px 10px;
        background: rgba(0, 40, 18, 0.35);
      }
      dt {
        font-size: 10px;
        letter-spacing: 0.15em;
        opacity: 0.65;
      }
      dd {
        margin: 2px 0 0;
        font-size: 14px;
        font-weight: 700;
        color: #baffd7;
        text-shadow: 0 0 8px rgba(0, 255, 120, 0.5);
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
      }
      .scope {
        flex: 1;
        width: 100%;
        max-width: 760px;
        display: flex;
        align-items: center;
        justify-content: center;
      }
      /* Positioning context that holds the round CRT plus the flat, unclipped
         label layer stacked on top of it. Shrinks to fit the CRT. */
      .crt-wrap {
        position: relative;
        display: inline-flex;
        width: min(88vw, 72vh, 720px);
        aspect-ratio: 1 / 1;
      }
      /* Circular outer halo drawn behind the (masked) tube, so the green glow
         keeps its round shape after the mask on .crt clips its own box-shadow. */
      .crt-wrap::before {
        content: '';
        position: absolute;
        inset: 0;
        z-index: -1;
        border-radius: 50%;
        pointer-events: none;
        box-shadow: 0 0 40px rgba(0, 255, 120, 0.25);
      }
      /* CRT enclosure: holds the radar canvas plus the scanline/glare overlays
         that give it the look of a curved phosphor tube. */
      .crt {
        position: relative;
        width: 100%;
        height: 100%;
        border-radius: 50%;
        overflow: hidden;
        isolation: isolate;
        /* Safari/WebKit ignores `overflow: hidden` + `border-radius` for
           children promoted to their own compositing layer (transform,
           backface-visibility, mix-blend-mode, animation), letting the rolling
           bar and scanline overlays leak into the square's corners. A circular
           mask forces the clip to be applied after compositing, so composited
           descendants stay inside the tube on every browser. */
        -webkit-mask-image: radial-gradient(circle closest-side at 50% 50%, #000 99.5%, transparent 100%);
        mask-image: radial-gradient(circle closest-side at 50% 50%, #000 99.5%, transparent 100%);
        /* Only the inset glow lives here; the mask above would clip an outer
           box-shadow. The outer halo is drawn by .crt-wrap::before instead. */
        box-shadow: inset 0 0 60px rgba(0, 255, 120, 0.08);
      }
      /* Info-card layer: same coordinate space as the radar canvas but placed
         above the circular clip and every CRT overlay, so cards are drawn in
         full and on top of all other elements. */
      .label-layer {
        position: absolute;
        inset: 0;
        z-index: 10;
        width: 100%;
        height: 100%;
        pointer-events: none;
      }
      #radar {
        display: block;
        width: 100%;
        height: 100%;
        border-radius: 50%;
        /* Faint horizontal smear mimics phosphor bleed between scanlines. */
        filter: saturate(1.1) contrast(1.05);
        /* The tube "flicker" lives on the canvas rather than on .crt so the
           parent that hosts the overlays never becomes an animating opacity
           group, which on several mobile GPUs drops the overlays over part of
           the circle. */
        animation: crt-flicker 5s infinite;
      }
      /* Static scanlines drawn over the whole tube. These deliberately avoid
         mix-blend-mode and GPU layer promotion (translateZ/backface-visibility):
         blending against the tube on some mobile/tablet GPUs only paints part
         of the circle (e.g. a single corner). Over this near-black backdrop a
         plain translucent overlay is visually indistinguishable from multiply
         but is painted in the normal raster, so it always fills the circle. */
      .crt::before {
        content: '';
        position: absolute;
        inset: 0;
        z-index: 2;
        border-radius: 50%;
        pointer-events: none;
        background: repeating-linear-gradient(
          to bottom,
          rgba(0, 0, 0, 0) 0,
          rgba(0, 0, 0, 0) 2px,
          rgba(0, 20, 8, 0.4) 3px,
          rgba(0, 20, 8, 0.4) 4px
        );
      }
      /* Curved-glass vignette plus a soft top glare highlight. */
      .crt::after {
        content: '';
        position: absolute;
        inset: 0;
        z-index: 3;
        border-radius: 50%;
        pointer-events: none;
        background:
          radial-gradient(ellipse 60% 40% at 50% 16%, rgba(200, 255, 220, 0.08), rgba(200, 255, 220, 0) 60%),
          radial-gradient(circle at 50% 50%, rgba(0, 0, 0, 0) 52%, rgba(0, 10, 4, 0.65) 100%);
      }
      /* Rolling refresh bar that drifts down the tube like a real CRT. Uses
         plain alpha (no screen blend) for the same cross-GPU reason as above. */
      .crt-roll {
        position: absolute;
        left: 0;
        right: 0;
        top: -25%;
        height: 25%;
        z-index: 2;
        pointer-events: none;
        background: linear-gradient(
          to bottom,
          rgba(140, 255, 190, 0) 0%,
          rgba(140, 255, 190, 0.09) 50%,
          rgba(140, 255, 190, 0) 100%
        );
        animation: crt-roll 7s linear infinite;
      }
      @keyframes crt-roll {
        0% { transform: translateY(0); }
        100% { transform: translateY(500%); }
      }
      @keyframes crt-flicker {
        0%, 100% { opacity: 1; }
        7% { opacity: 0.94; }
        9% { opacity: 1; }
        41% { opacity: 0.98; }
        43% { opacity: 0.9; }
        45% { opacity: 1; }
        78% { opacity: 0.96; }
      }
      @media (prefers-reduced-motion: reduce) {
        #radar { animation: none; }
        .crt-roll { display: none; }
      }
      footer.hud { text-align: center; }
      #status {
        margin: 0;
        font-size: 13px;
        min-height: 1.2em;
      }
      #status[data-kind='ok'] { color: #9dffc4; }
      #status[data-kind='warn'] { color: #ffe37a; }
      #status[data-kind='error'] { color: #ff8a8a; }
      .credit {
        margin: 6px 0 0;
        font-size: 10px;
        opacity: 0.5;
        letter-spacing: 0.08em;
      }

      .fs-btn {
        position: fixed;
        top: calc(14px + env(safe-area-inset-top, 0px));
        right: calc(14px + env(safe-area-inset-right, 0px));
        z-index: 500;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--green);
        background: rgba(0, 40, 18, 0.5);
        border: 1px solid rgba(0, 255, 120, 0.4);
        border-radius: 8px;
        padding: 8px;
        cursor: pointer;
        opacity: 0.55;
        transition: opacity 0.15s ease, background 0.15s ease;
      }
      /* Author `display: flex` above would otherwise override the HTML hidden
         attribute and keep unsupported controls (e.g. compass) visible. */
      .fs-btn[hidden] {
        display: none !important;
      }
      .fs-btn:hover {
        opacity: 1;
        background: rgba(0, 255, 120, 0.2);
      }
      .fs-icon-collapse { display: none; }

      /* Groups the top-left buttons so they sit side by side regardless of the
         passport label's width. Its children opt out of the fixed positioning
         the .fs-btn base rule sets. */
      .corner-controls {
        position: fixed;
        top: calc(14px + env(safe-area-inset-top, 0px));
        z-index: 500;
        display: flex;
        align-items: stretch;
        gap: 8px;
      }
      .corner-left { left: calc(14px + env(safe-area-inset-left, 0px)); }
      .corner-controls .fs-btn {
        position: static;
        top: auto;
        left: auto;
        right: auto;
      }

      .passport-btn {
        gap: 8px;
        padding: 8px 12px;
      }
      /* Deliberately faint so it stays out of the way until you look for it. */
      .dev-toggle { opacity: 0.32; }
      .passport-btn-label {
        font-size: 12px;
        letter-spacing: 0.12em;
        text-transform: uppercase;
      }

      /* Sound toggle sits just left of the fullscreen button (top-right). */
      .sound-btn { right: calc(60px + env(safe-area-inset-right, 0px)); }
      /* Show the muted (crossed-out) glyph until sound is enabled. */
      .snd-icon-off { display: none; }
      .sound-btn[aria-pressed='false'] .snd-icon-on { display: none; }
      .sound-btn[aria-pressed='false'] .snd-icon-off { display: block; }
      .sound-btn[aria-pressed='true'] { opacity: 0.9; color: #baffd7; }

      /* Compass lock: left of sound. Hidden until JS confirms a mobile /
         orientation-capable device, so desktop never shows a dead control. */
      .compass-btn { right: calc(106px + env(safe-area-inset-right, 0px)); }
      .compass-btn .compass-needle-fill { display: none; }
      .compass-btn[aria-pressed='true'] {
        opacity: 1;
        color: #e6ffef;
        background: rgba(0, 255, 120, 0.28);
        border-color: rgba(160, 255, 200, 0.95);
        box-shadow: 0 0 12px rgba(0, 255, 120, 0.45);
      }
      /* Solid needle when locked so the on-state reads at a glance. */
      .compass-btn[aria-pressed='true'] .compass-needle-stroke { display: none; }
      .compass-btn[aria-pressed='true'] .compass-needle-fill { display: block; }

      /* ---- Dev / demo panel ----------------------------------------------- */
      .dev-panel[hidden] { display: none; }
      .dev-panel {
        position: fixed;
        left: 14px;
        bottom: 14px;
        z-index: 700;
        width: 220px;
        padding: 10px 12px 12px;
        background: rgba(4, 20, 11, 0.92);
        border: 1px solid rgba(0, 255, 120, 0.4);
        border-radius: 10px;
        box-shadow: 0 0 30px rgba(0, 255, 120, 0.2);
        backdrop-filter: blur(3px);
      }
      .dev-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        font-size: 11px;
        letter-spacing: 0.2em;
        opacity: 0.85;
        margin-bottom: 8px;
      }
      .dev-buttons {
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
        margin-bottom: 6px;
      }
      .dev-buttons button {
        font: inherit;
        font-size: 11px;
        letter-spacing: 0.04em;
        color: var(--green);
        background: rgba(0, 255, 120, 0.1);
        border: 1px solid rgba(0, 255, 120, 0.35);
        border-radius: 5px;
        padding: 5px 8px;
        cursor: pointer;
        transition: background 0.15s ease;
      }
      .dev-buttons button:hover { background: rgba(0, 255, 120, 0.25); }
      .dev-hint {
        margin: 4px 0 0;
        font-size: 10px;
        opacity: 0.5;
      }
      .dev-hint kbd,
      .dev-hint code {
        color: #baffd7;
        background: rgba(0, 255, 120, 0.12);
        border-radius: 3px;
        padding: 0 4px;
      }

      /* Immersive wall mode: radar edge to edge, HUD boxes hidden. */
      body.immersive .app {
        padding: 0;
        gap: 0;
        justify-content: center;
      }
      body.immersive .hud { display: none; }
      body.immersive .scope { max-width: none; }
      body.immersive .crt-wrap {
        width: min(90vw, 90vh);
        max-width: none;
      }
      body.immersive .fs-icon-expand { display: none; }
      body.immersive .fs-icon-collapse { display: block; }

      /* On narrow / portrait screens there isn't enough horizontal room for the
         HUD title to sit between the fixed corner buttons (passport on the left,
         sound + fullscreen on the right), so they overlap. Drop the header below
         the top button row by reserving vertical space. The immersive rule above
         still wins (higher specificity) and keeps its padding: 0. */
      @media (max-width: 900px) {
        .app { padding-top: 64px; }
      }

      .range-cell {
        display: flex;
        align-items: center;
        gap: 8px;
        min-width: 0;
      }
      .range-cell > span {
        min-width: 0;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
      }
      .range-edit {
        flex: none;
        font: inherit;
        font-size: 10px;
        letter-spacing: 0.1em;
        color: var(--green);
        background: rgba(0, 255, 120, 0.1);
        border: 1px solid rgba(0, 255, 120, 0.4);
        border-radius: 4px;
        padding: 2px 8px;
        cursor: pointer;
        transition: background 0.15s ease;
      }
      .range-edit:hover {
        background: rgba(0, 255, 120, 0.25);
      }
      .range-edit:disabled {
        opacity: 0.45;
        cursor: wait;
      }

      .modal[hidden] { display: none; }
      .modal {
        position: fixed;
        inset: 0;
        z-index: 1000;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 16px;
        background: rgba(2, 10, 5, 0.75);
        backdrop-filter: blur(3px);
      }
      .modal-card {
        width: 100%;
        max-width: 560px;
        background: #041a0d;
        border: 1px solid rgba(0, 255, 120, 0.35);
        border-radius: 10px;
        box-shadow: 0 0 40px rgba(0, 255, 120, 0.25);
        overflow: hidden;
      }
      .modal-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 12px 14px;
        font-size: 12px;
        letter-spacing: 0.15em;
        border-bottom: 1px solid rgba(0, 255, 120, 0.2);
      }
      .icon-btn {
        font: inherit;
        font-size: 20px;
        line-height: 1;
        color: var(--green);
        background: none;
        border: none;
        cursor: pointer;
        padding: 0 4px;
      }
      .map {
        width: 100%;
        height: 340px;
        background: #04120a;
      }
      .modal-controls {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 12px 14px 4px;
      }
      #range-slider {
        flex: 1;
        accent-color: var(--green);
      }
      #range-value {
        min-width: 56px;
        text-align: right;
        font-weight: 700;
        color: #baffd7;
      }
      .center-search {
        flex: 1;
        min-width: 0;
        font: inherit;
        font-size: 13px;
        color: #baffd7;
        background: rgba(0, 40, 18, 0.5);
        border: 1px solid rgba(0, 255, 120, 0.35);
        border-radius: 5px;
        padding: 7px 10px;
      }
      .center-search::placeholder { color: rgba(0, 255, 120, 0.4); }
      .geo-btn {
        flex: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        font: inherit;
        font-size: 13px;
        letter-spacing: 0.06em;
        color: var(--green);
        background: rgba(0, 255, 120, 0.1);
        border: 1px solid rgba(0, 255, 120, 0.4);
        border-radius: 6px;
        padding: 9px 14px;
        cursor: pointer;
        transition: background 0.15s ease;
      }
      .geo-btn:hover { background: rgba(0, 255, 120, 0.22); }
      .geo-btn svg { display: block; }
      .center-search:focus {
        outline: none;
        border-color: var(--green);
        box-shadow: 0 0 8px rgba(0, 255, 120, 0.35);
      }
      #center-value {
        flex: 1;
        min-width: 0;
        font-weight: 700;
        color: #baffd7;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
      }
      .range-apply {
        font: inherit;
        letter-spacing: 0.1em;
        color: #02160b;
        background: var(--green);
        border: none;
        border-radius: 5px;
        padding: 6px 14px;
        font-weight: 700;
        cursor: pointer;
      }
      .range-apply:hover { filter: brightness(1.1); }
      .modal-hint {
        margin: 0;
        padding: 0 14px 12px;
        font-size: 11px;
        opacity: 0.55;
      }

      /* The passport is the app's richest surface: a big, tabbed modal. Lay it
         out as a column so the header + tab bar stay pinned while the active
         panel scrolls. */
      .passport-card {
        max-width: 940px;
        width: 100%;
        display: flex;
        flex-direction: column;
        /* Fixed height so switching tabs never resizes the card; the active
           panel scrolls within the body instead of the whole modal jumping. */
        height: 92vh;
      }
      .passport-tabs {
        display: flex;
        flex-wrap: wrap;
        gap: 2px;
        padding: 8px 10px 0;
        border-bottom: 1px solid rgba(0, 255, 120, 0.2);
      }
      .passport-tab {
        font: inherit;
        font-size: 11px;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--green);
        background: transparent;
        border: 1px solid transparent;
        border-bottom: none;
        border-radius: 6px 6px 0 0;
        padding: 7px 12px;
        cursor: pointer;
        opacity: 0.6;
        transition: opacity 0.15s ease, background 0.15s ease;
      }
      .passport-tab:hover { opacity: 0.9; background: rgba(0, 255, 120, 0.08); }
      .passport-tab.is-active {
        opacity: 1;
        color: #baffd7;
        background: rgba(0, 255, 120, 0.12);
        border-color: rgba(0, 255, 120, 0.35);
        text-shadow: 0 0 8px rgba(0, 255, 120, 0.5);
      }
      /* The body is a fixed-height column; the active panel fills it and owns
         its own scroll, so shared chrome (header, tabs) and per-tab furniture
         (like the Countries map) stay pinned instead of scrolling away. */
      .passport-body {
        flex: 1;
        min-height: 0;
        display: flex;
        flex-direction: column;
        overflow: hidden;
      }
      .passport-panel {
        flex: 1 1 auto;
        min-height: 0;
        overflow-y: auto;
        /* Keep a panel's own scroll from chaining out to the page behind. */
        overscroll-behavior: contain;
      }
      .passport-panel[hidden] { display: none; }
      /* Countries / Routes tabs: pin the map (Countries) and detail panels,
         and let only the entries list scroll. */
      #tab-countries:not([hidden]),
      #tab-routes:not([hidden]) {
        display: flex;
        flex-direction: column;
        overflow: hidden;
      }
      /* Countries notice pinned to the top of the scrolling body so it stays
         visible no matter how far the list is scrolled. */
      .modal-hint-sticky {
        flex: none;
        margin: 0;
        padding: 10px 14px;
        background: #041a0d;
        border-bottom: 1px solid rgba(0, 255, 120, 0.2);
        opacity: 1;
      }

      /* CRT enclosure for the world map: same scanline/glare/vignette treatment
         as the round radar tube, but rectangular. The map sits at the bottom of
         the stack; the overlays below are painted on top and ignore pointer
         events so panning/zooming still works. */
      .passport-crt {
        flex: none;
        position: relative;
        overflow: hidden;
        isolation: isolate;
        border-bottom: 1px solid rgba(0, 255, 120, 0.2);
      }
      .passport-map {
        height: clamp(200px, 32vh, 300px);
        /* Ocean is black; the seamless land layer paints continents black with
           a green coastline, so the map reads as green outlines on a dark tube
           with visited countries filled green. */
        background: #000000;
      }
      /* Leaflet paints a light grey backdrop by default; keep the tube dark. */
      .passport-map :global(.leaflet-container) {
        background: transparent;
        font-family: 'Share Tech Mono', ui-monospace, SFMono-Regular, Menlo, monospace;
      }
      /* A faint green bloom on the outlines so visited countries glow softly
         without overpowering the map. */
      .passport-map :global(.leaflet-overlay-pane) {
        filter: drop-shadow(0 0 1px rgba(0, 255, 120, 0.35));
      }
      /* Tint Leaflet's tooltips to match the HUD instead of the default white. */
      .passport-map :global(.leaflet-tooltip) {
        background: rgba(4, 26, 13, 0.92);
        border: 1px solid rgba(0, 255, 120, 0.4);
        border-radius: 4px;
        color: #baffd7;
        font-size: 11px;
        letter-spacing: 0.04em;
        box-shadow: 0 0 10px rgba(0, 255, 120, 0.25);
      }
      .passport-map :global(.leaflet-tooltip-top::before),
      .passport-map :global(.leaflet-tooltip-bottom::before),
      .passport-map :global(.leaflet-tooltip-left::before),
      .passport-map :global(.leaflet-tooltip-right::before) {
        display: none;
      }
      /* Restyle the zoom control as a HUD element rather than the light default. */
      .passport-map :global(.leaflet-control-zoom a) {
        background: rgba(4, 26, 13, 0.9);
        border: 1px solid rgba(0, 255, 120, 0.35);
        color: var(--green);
        text-shadow: 0 0 6px rgba(0, 255, 120, 0.5);
      }
      .passport-map :global(.leaflet-control-zoom a:hover) {
        background: rgba(0, 255, 120, 0.2);
      }
      /* Very faint static scanlines for a hint of CRT texture. */
      .passport-crt::before {
        content: '';
        position: absolute;
        inset: 0;
        z-index: 400;
        pointer-events: none;
        background: repeating-linear-gradient(
          to bottom,
          rgba(0, 0, 0, 0) 0,
          rgba(0, 0, 0, 0) 3px,
          rgba(0, 20, 8, 0.14) 4px
        );
        mix-blend-mode: multiply;
      }
      /* Subtle edge vignette so the corners fall off gently. */
      .passport-crt::after {
        content: '';
        position: absolute;
        inset: 0;
        z-index: 401;
        pointer-events: none;
        background: radial-gradient(
          ellipse 100% 100% at 50% 50%,
          rgba(0, 0, 0, 0) 70%,
          rgba(0, 10, 4, 0.35) 100%
        );
      }
      .modal-head-actions {
        display: flex;
        align-items: center;
        gap: 10px;
      }
      .modal-title {
        display: flex;
        flex-direction: column;
        gap: 3px;
        min-width: 0;
      }
      .passport-opened {
        font-size: 9px;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: rgba(0, 255, 120, 0.5);
      }
      .passport-opened:empty { display: none; }
      .passport-reset {
        font: inherit;
        font-size: 10px;
        letter-spacing: 0.1em;
        color: rgba(0, 255, 120, 0.7);
        background: transparent;
        border: 1px solid rgba(0, 255, 120, 0.3);
        border-radius: 4px;
        padding: 3px 9px;
        cursor: pointer;
        transition: background 0.15s ease, color 0.15s ease, border-color 0.15s ease;
      }
      .passport-reset:hover {
        background: rgba(255, 60, 60, 0.14);
        border-color: rgba(255, 90, 90, 0.5);
        color: #ff9a9a;
      }
      .passport-reset:focus-visible {
        outline: 2px solid rgba(0, 255, 120, 0.5);
        outline-offset: 2px;
      }
      /* Share reuses the subtle outlined look of Reset but keeps the friendly
         green hover (Reset goes red because it's destructive). */
      .passport-share:hover {
        background: rgba(0, 255, 120, 0.16);
        border-color: rgba(0, 255, 120, 0.55);
        color: #d9ffec;
      }

      /* Passport on phones (iPhone SE and similar): reclaim vertical space so
         the map, chip list, and detail panel can coexist without clipping. */
      @media (max-width: 600px) {
        #passport-modal.modal {
          padding: 0;
          align-items: stretch;
        }
        .passport-card {
          max-width: none;
          width: 100%;
          height: 100%;
          height: 100dvh;
          border-radius: 0;
          border-left: none;
          border-right: none;
        }
        .passport-card .modal-head {
          align-items: flex-start;
          gap: 8px;
          padding: 10px 12px;
          flex-wrap: wrap;
        }
        .passport-card .modal-title {
          flex: 1 1 auto;
          min-width: 0;
        }
        .passport-card .modal-head-actions {
          flex: none;
          margin-left: auto;
          gap: 6px;
        }
        .passport-reset {
          font-size: 9px;
          letter-spacing: 0.08em;
          padding: 3px 7px;
        }
        .passport-tabs {
          display: grid;
          grid-template-columns: repeat(3, 1fr);
          gap: 0;
          padding: 0;
        }
        .passport-tab {
          font-size: 10px;
          letter-spacing: 0.06em;
          padding: 8px 4px;
          text-align: center;
          border-radius: 0;
          border: none;
          border-bottom: 2px solid transparent;
        }
        .passport-tab.is-active {
          border-color: transparent;
          border-bottom-color: var(--green);
          background: rgba(0, 255, 120, 0.1);
        }
        .modal-hint-sticky {
          padding: 8px 12px;
          font-size: 10px;
          line-height: 1.35;
        }
        .passport-map {
          height: min(160px, 24vh);
        }
        .passport-list {
          min-height: 64px;
          padding: 6px 12px 8px;
        }
        .country-detail:not(:empty) {
          padding: 8px 12px 12px;
        }
        #tab-countries:has(.country-flight-list) .passport-map,
        #tab-routes:has(.country-flight-list) .passport-map {
          height: min(120px, 18vh);
        }
        #tab-countries:has(.country-flight-list) .country-detail,
        #tab-routes:has(.country-flight-list) .country-detail {
          min-height: 200px;
        }
      }

      /* Share-card preview modal: a portrait canvas rendered to an <img>. */
      .share-card { max-width: 460px; }
      .share-body {
        display: flex;
        flex-direction: column;
        gap: 14px;
        padding: 16px 16px 8px;
      }
      .share-preview {
        display: flex;
        justify-content: center;
        max-height: 64vh;
        overflow: auto;
      }
      .share-preview img {
        width: 100%;
        max-width: 360px;
        height: auto;
        border: 1px solid rgba(0, 255, 120, 0.3);
        border-radius: 8px;
        box-shadow: 0 0 24px rgba(0, 255, 120, 0.2);
      }
      .share-actions {
        display: flex;
        gap: 10px;
        justify-content: center;
        flex-wrap: wrap;
      }
      .share-actions .range-apply { padding: 9px 18px; }
      .share-native {
        color: var(--green);
        background: transparent;
        border: 1px solid rgba(0, 255, 120, 0.45);
      }
      .share-native:hover { background: rgba(0, 255, 120, 0.14); filter: none; }
      .share-hint { text-align: center; }
      .passport-list {
        flex: 1 1 auto;
        min-height: 100px;
        overflow-y: auto;
        overscroll-behavior: contain;
        display: flex;
        flex-direction: column;
        gap: 10px;
        padding: 6px 14px 10px;
      }
      .passport-chips {
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
      }
      .passport-routes {
        display: flex;
        flex-direction: column;
        gap: 6px;
      }
      .passport-map :global(.leaflet-tooltip) .tip-flight {
        display: block;
        margin-top: 2px;
        opacity: 0.75;
        font-size: 10px;
      }
      .passport-map :global(.leaflet-tooltip) .tip-hint {
        display: block;
        margin-top: 2px;
        opacity: 0.5;
        font-size: 9px;
        letter-spacing: 0.1em;
        text-transform: uppercase;
      }
      .passport-chip {
        font: inherit;
        font-size: 11px;
        color: #baffd7;
        background: rgba(0, 255, 120, 0.1);
        border: 1px solid rgba(0, 255, 120, 0.3);
        border-radius: 12px;
        padding: 2px 9px;
        white-space: nowrap;
        cursor: pointer;
        transition: background 0.15s ease, border-color 0.15s ease;
      }
      .passport-chip:hover { background: rgba(0, 255, 120, 0.22); }
      .passport-chip.is-selected {
        background: rgba(0, 255, 120, 0.3);
        border-color: #baffd7;
        color: #eafff2;
      }
      /* Routes tab: full-width cards instead of compact chips. */
      .passport-route-card {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        width: 100%;
        box-sizing: border-box;
        font: inherit;
        font-size: 13px;
        text-align: left;
        color: #d3ffe6;
        background: rgba(0, 40, 18, 0.28);
        border: 1px solid rgba(0, 255, 120, 0.2);
        border-radius: 6px;
        padding: 10px 12px;
        cursor: pointer;
        transition: background 0.15s ease, border-color 0.15s ease;
      }
      .passport-route-card:hover {
        background: rgba(0, 255, 120, 0.14);
        border-color: rgba(0, 255, 120, 0.4);
      }
      .passport-route-card.is-selected {
        background: rgba(0, 255, 120, 0.22);
        border-color: #baffd7;
        color: #eafff2;
      }
      .passport-route-ends {
        display: flex;
        align-items: baseline;
        flex-wrap: wrap;
        gap: 6px;
        min-width: 0;
        font-weight: 700;
      }
      .passport-route-arrow {
        color: var(--green);
        opacity: 0.7;
        font-weight: 700;
      }
      .passport-route-count {
        flex: none;
        font-size: 11px;
        font-weight: 400;
        letter-spacing: 0.06em;
        opacity: 0.7;
        white-space: nowrap;
      }
      .passport-empty {
        margin: 0;
        font-size: 12px;
        opacity: 0.55;
      }

      /* ---- Detail panel (Countries / Routes tabs) ------------------------- */
      /* Pinned below the scrolling entries list. The head stays put; the flight
         list fills remaining space and scrolls on its own. */
      .country-detail {
        flex: none;
        max-height: 48%;
        display: flex;
        flex-direction: column;
        min-height: 0;
        overflow: hidden;
        overscroll-behavior: contain;
        padding: 0;
      }
      .country-detail:not(:empty) {
        border-top: 1px solid rgba(0, 255, 120, 0.2);
        padding: 8px 14px 14px;
      }
      .passport-hint {
        margin: 0;
        font-size: 12px;
        opacity: 0.55;
      }
      .country-detail-head {
        flex: none;
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        gap: 12px;
        flex-wrap: wrap;
        margin-bottom: 6px;
      }
      .country-detail-title {
        font-size: 15px;
        font-weight: 700;
        color: #baffd7;
        text-shadow: 0 0 8px rgba(0, 255, 120, 0.4);
      }
      .country-detail-meta {
        font-size: 11px;
        opacity: 0.6;
        letter-spacing: 0.04em;
        margin-left: auto;
      }
      .country-detail-clear {
        font: inherit;
        font-size: 16px;
        line-height: 1;
        color: var(--green);
        background: rgba(0, 255, 120, 0.1);
        border: 1px solid rgba(0, 255, 120, 0.4);
        border-radius: 4px;
        padding: 1px 8px;
        cursor: pointer;
        transition: background 0.15s ease;
      }
      .country-detail-clear:hover { background: rgba(0, 255, 120, 0.25); }
      .country-flight-list {
        list-style: none;
        margin: 0;
        padding: 0;
        flex: 1 1 auto;
        min-height: 0;
        display: flex;
        flex-direction: column;
        gap: 8px;
        overflow-y: auto;
        /* Scroll the flight list on its own; don't chain out to the modal body
           once the top/bottom is reached. */
        overscroll-behavior: contain;
      }

      /* When a country/route is pinned, reclaim map + hint space so the flight
         list has room to breathe. */
      #tab-countries:has(.country-flight-list) .modal-hint-sticky,
      #tab-routes:has(.country-flight-list) .modal-hint-sticky {
        display: none;
      }
      #tab-countries:has(.country-flight-list) .passport-map {
        height: clamp(140px, 22vh, 220px);
      }
      #tab-countries:has(.country-flight-list) .passport-list,
      #tab-routes:has(.country-flight-list) .passport-list {
        flex: 0 1 auto;
        max-height: 30%;
        min-height: 56px;
      }
      #tab-countries:has(.country-flight-list) .country-detail,
      #tab-routes:has(.country-flight-list) .country-detail {
        flex: 1 1 50%;
        max-height: none;
        min-height: 220px;
      }
      .cflight {
        padding: 7px 10px;
        border: 1px solid rgba(0, 255, 120, 0.15);
        border-radius: 6px;
        background: rgba(0, 40, 18, 0.28);
      }
      .cflight-route {
        display: flex;
        align-items: baseline;
        flex-wrap: wrap;
        gap: 6px;
        font-size: 13px;
        color: #d3ffe6;
      }
      .cflight-place { font-weight: 700; }
      /* The endpoint that is the country you're viewing is highlighted. */
      .cflight-place.is-here {
        color: #eafff2;
        text-shadow: 0 0 8px rgba(0, 255, 120, 0.5);
      }
      .cflight-arrow {
        color: var(--green);
        opacity: 0.7;
        font-weight: 700;
      }
      .cflight-meta {
        margin-top: 3px;
        font-size: 11px;
        color: #8fd4ad;
        opacity: 0.85;
        letter-spacing: 0.02em;
      }

      /* ---- Logbook tables (Aircraft / Airlines) --------------------------- */
      .log-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 12px;
      }
      .log-table thead th {
        position: sticky;
        top: 0;
        z-index: 1;
        text-align: left;
        font-size: 10px;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--green);
        opacity: 0.8;
        background: #041a0d;
        padding: 10px 14px 8px;
        border-bottom: 1px solid rgba(0, 255, 120, 0.25);
      }
      .log-table th.log-count,
      .log-table td.log-count { text-align: right; }
      .log-table tbody td {
        padding: 7px 14px;
        border-bottom: 1px solid rgba(0, 255, 120, 0.08);
        color: #a9e8c4;
      }
      .log-table tbody tr:hover td { background: rgba(0, 255, 120, 0.06); }
      .log-code {
        font-weight: 700;
        color: #baffd7;
        letter-spacing: 0.04em;
      }
      .log-name { color: #9fe0bd; }
      .log-first { opacity: 0.7; font-size: 11px; }
      .log-count {
        font-weight: 700;
        color: #baffd7;
        font-variant-numeric: tabular-nums;
      }
      .log-tag-cell { white-space: nowrap; }
      .log-tag {
        display: inline-block;
        font-size: 9px;
        letter-spacing: 0.08em;
        border-radius: 4px;
        padding: 1px 5px;
        margin-right: 4px;
      }
      .tag-rare {
        color: #bfe9ff;
        background: rgba(120, 225, 255, 0.14);
        border: 1px solid rgba(120, 225, 255, 0.5);
      }
      .tag-mil {
        color: #ffe6a0;
        background: rgba(255, 205, 70, 0.14);
        border: 1px solid rgba(255, 205, 70, 0.5);
      }
      .log-empty {
        padding: 24px 14px;
        text-align: center;
        opacity: 0.5;
        font-size: 12px;
      }

      /* ---- Aircraft thumbnails (Planespotters) ---------------------------- */
      .log-photo-cell {
        width: 68px;
        padding: 5px 6px 5px 14px !important;
      }
      .log-photo {
        width: 56px;
        height: 38px;
        border-radius: 4px;
        overflow: hidden;
        background: rgba(0, 255, 120, 0.05);
        border: 1px solid rgba(0, 255, 120, 0.15);
        display: flex;
        align-items: center;
        justify-content: center;
      }
      /* A faint pulse while the thumbnail is being fetched. */
      .log-photo.is-loading {
        background:
          linear-gradient(100deg, rgba(0, 255, 120, 0.04) 30%, rgba(0, 255, 120, 0.14) 50%, rgba(0, 255, 120, 0.04) 70%)
          rgba(0, 255, 120, 0.05);
        background-size: 200% 100%;
        animation: log-photo-shimmer 1.1s ease-in-out infinite;
      }
      @keyframes log-photo-shimmer {
        from { background-position: 200% 0; }
        to { background-position: -200% 0; }
      }
      /* No photo available: a small camera-off style dash. */
      .log-photo.is-empty {
        border-style: dashed;
        opacity: 0.4;
      }
      .log-photo.is-empty::after {
        content: '\2014';
        font-size: 12px;
        color: var(--green);
      }
      .log-photo-btn {
        display: block;
        width: 100%;
        height: 100%;
        padding: 0;
        border: none;
        background: transparent;
        cursor: zoom-in;
      }
      .log-photo-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
        transition: transform 0.2s ease;
      }
      .log-photo-btn:hover .log-photo-img { transform: scale(1.08); }
      .log-photo-btn:focus-visible {
        outline: 2px solid var(--green);
        outline-offset: 1px;
      }

      /* ---- Airline logos (Daisycon) --------------------------------------- */
      .log-logo-cell {
        width: 68px;
        padding: 5px 6px 5px 14px !important;
      }
      /* Logos sit on a light chip so dark/colour marks stay legible against the
         dark CRT theme; the image is contained (not cropped) to keep wordmarks
         whole. */
      .log-logo {
        width: 56px;
        height: 30px;
        border-radius: 4px;
        overflow: hidden;
        background: rgba(233, 255, 243, 0.92);
        border: 1px solid rgba(0, 255, 120, 0.15);
        display: flex;
        align-items: center;
        justify-content: center;
      }
      .log-logo.is-loading {
        background:
          linear-gradient(100deg, rgba(0, 255, 120, 0.04) 30%, rgba(0, 255, 120, 0.14) 50%, rgba(0, 255, 120, 0.04) 70%)
          rgba(0, 255, 120, 0.05);
        background-size: 200% 100%;
        animation: log-photo-shimmer 1.1s ease-in-out infinite;
      }
      .log-logo.is-empty {
        border-style: dashed;
        background: rgba(0, 255, 120, 0.05);
        opacity: 0.4;
      }
      .log-logo.is-empty::after {
        content: '\2014';
        font-size: 12px;
        color: var(--green);
      }
      .log-logo-img {
        max-width: 100%;
        max-height: 100%;
        object-fit: contain;
        display: block;
      }

      /* ---- Photo lightbox ------------------------------------------------- */
      .photo-lightbox[hidden] { display: none; }
      .photo-lightbox {
        position: fixed;
        inset: 0;
        z-index: 1100;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 24px;
        background: rgba(0, 6, 3, 0.82);
        backdrop-filter: blur(2px);
      }
      .photo-lightbox-figure {
        position: relative;
        margin: 0;
        max-width: min(560px, 92vw);
        background: #041a0d;
        border: 1px solid rgba(0, 255, 120, 0.4);
        border-radius: 8px;
        box-shadow: 0 0 30px rgba(0, 255, 120, 0.2);
        padding: 12px;
      }
      .photo-lightbox-close {
        position: absolute;
        top: 6px;
        right: 6px;
        z-index: 1;
      }
      .photo-lightbox-title {
        display: block;
        font-size: 12px;
        font-weight: 700;
        letter-spacing: 0.08em;
        color: #baffd7;
        margin: 2px 28px 8px 2px;
        text-shadow: 0 0 8px rgba(0, 255, 120, 0.4);
      }
      .photo-lightbox-img {
        display: block;
        max-width: 100%;
        max-height: 60vh;
        border-radius: 4px;
        background: rgba(0, 255, 120, 0.05);
      }
      .photo-lightbox-credit {
        margin-top: 8px;
        font-size: 11px;
        opacity: 0.85;
        color: #a9e8c4;
      }
      .photo-lightbox-credit a {
        color: var(--green);
        text-decoration: underline;
      }
      .photo-lightbox-credit a:hover { opacity: 0.85; }

      /* ---- Badges --------------------------------------------------------- */
      .badges-head {
        padding: 12px 14px 4px;
        font-size: 12px;
        font-weight: 700;
        color: #baffd7;
        letter-spacing: 0.08em;
        text-shadow: 0 0 8px rgba(0, 255, 120, 0.4);
      }
      .badges-wrap {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
        gap: 10px;
        padding: 8px 14px 16px;
      }
      .badge {
        display: flex;
        flex-direction: column;
        gap: 3px;
        padding: 12px;
        border-radius: 8px;
        border: 1px solid rgba(0, 255, 120, 0.2);
        background: rgba(0, 40, 18, 0.3);
      }
      .badge.is-earned {
        border-color: rgba(0, 255, 120, 0.55);
        background: rgba(0, 255, 120, 0.1);
        box-shadow: 0 0 16px rgba(0, 255, 120, 0.15);
      }
      .badge.is-locked { opacity: 0.5; }
      .badge-star {
        font-size: 18px;
        line-height: 1;
        color: var(--green);
      }
      .badge.is-earned .badge-star {
        color: #eafff2;
        text-shadow: 0 0 10px rgba(0, 255, 120, 0.7);
      }
      .badge-name {
        font-size: 13px;
        font-weight: 700;
        color: #baffd7;
      }
      .badge-desc {
        font-size: 11px;
        opacity: 0.6;
        color: #9fe0bd;
      }
      .badge-detail {
        font-size: 11px;
        opacity: 0.75;
        color: #9fe0bd;
      }
      .badge.is-earned .badge-detail {
        opacity: 1;
        font-weight: 700;
        color: #d9ffec;
        text-shadow: 0 0 8px rgba(0, 255, 120, 0.35);
      }

      /* ---- Live "badge earned" toasts ------------------------------------ */
      /* Stack at the top of the scope, centred, never intercepting clicks so
         the radar stays fully usable underneath. */
      /* Focus-mode banner: pinned to the bottom of the viewport so it stays on
         screen whatever its height, clear of the tracked contact's info card in
         normal mode (and only lightly overlapping the scope in immersive), with
         a prominent Exit control so leaving focus mode is always obvious. */
      .focus-bar {
        position: fixed;
        bottom: 14px;
        left: 50%;
        transform: translateX(-50%);
        z-index: 30;
        display: flex;
        align-items: center;
        gap: 12px;
        max-width: 84%;
        padding: 6px 6px 6px 14px;
        border-radius: 999px;
        border: 1px solid rgba(0, 255, 120, 0.5);
        background: rgba(3, 22, 11, 0.85);
        box-shadow: 0 0 18px rgba(0, 255, 120, 0.28);
        backdrop-filter: blur(3px);
        color: #d6ffe6;
        font-family: 'Share Tech Mono', ui-monospace, SFMono-Regular, Menlo, monospace;
      }
      .focus-bar[hidden] { display: none; }
      /* Aircraft thumbnail on the left of the focus banner. Click to expand via
         the shared Planespotters lightbox, mirroring the passport logbook. */
      .focus-photo {
        flex: none;
        width: 62px;
        height: 40px;
        border-radius: 8px;
        overflow: hidden;
        border: 1px solid rgba(0, 255, 120, 0.35);
        background: rgba(0, 20, 10, 0.6);
      }
      .focus-photo[hidden] { display: none; }
      .focus-photo.is-loading {
        background:
          linear-gradient(100deg, rgba(0, 255, 120, 0) 30%, rgba(0, 255, 120, 0.12) 50%, rgba(0, 255, 120, 0) 70%)
          rgba(0, 20, 10, 0.6);
        background-size: 200% 100%;
        animation: focus-photo-shimmer 1.1s linear infinite;
      }
      @keyframes focus-photo-shimmer {
        from { background-position: 200% 0; }
        to { background-position: -200% 0; }
      }
      .focus-photo-btn {
        display: block;
        width: 100%;
        height: 100%;
        padding: 0;
        border: 0;
        margin: 0;
        cursor: zoom-in;
        background: none;
      }
      .focus-photo-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
      }
      .focus-info {
        display: flex;
        flex-direction: column;
        gap: 3px;
        min-width: 0;
      }
      .focus-head {
        display: flex;
        align-items: baseline;
        gap: 8px;
        min-width: 0;
      }
      /* Compact live telemetry: altitude, speed, heading, distance, squawk. */
      .focus-stats {
        display: flex;
        flex-wrap: wrap;
        gap: 2px 12px;
        font-size: 10px;
      }
      .focus-stats:empty { display: none; }
      .focus-stat {
        display: inline-flex;
        align-items: baseline;
        gap: 4px;
        white-space: nowrap;
      }
      .focus-stat-k {
        opacity: 0.5;
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }
      .focus-stat-v {
        color: #eafff2;
        font-weight: 700;
        text-shadow: 0 0 6px rgba(0, 255, 120, 0.35);
      }
      .focus-title {
        font-weight: bold;
        font-size: 14px;
        white-space: nowrap;
        text-shadow: 0 0 8px rgba(0, 255, 120, 0.5);
      }
      .focus-sub {
        font-size: 11px;
        opacity: 0.7;
        min-width: 0;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
      }
      .focus-exit {
        flex: none;
        cursor: pointer;
        border: 1px solid rgba(0, 255, 120, 0.55);
        background: rgba(0, 255, 120, 0.14);
        color: #eafff2;
        border-radius: 999px;
        padding: 5px 12px;
        font: inherit;
        font-size: 12px;
        line-height: 1;
        transition: background 0.15s ease;
      }
      .focus-exit:hover { background: rgba(0, 255, 120, 0.26); }
      .focus-exit:focus-visible { outline: 2px solid rgba(0, 255, 120, 0.8); outline-offset: 2px; }
      .badge-toasts {
        position: absolute;
        top: 10px;
        left: 50%;
        transform: translateX(-50%);
        z-index: 5;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 8px;
        width: max-content;
        max-width: 86%;
        pointer-events: none;
      }
      .badge-toast {
        display: flex;
        align-items: center;
        gap: 10px;
        max-width: 100%;
        padding: 8px 14px;
        border-radius: 999px;
        border: 1px solid rgba(0, 255, 120, 0.55);
        background: rgba(0, 30, 14, 0.82);
        box-shadow: 0 0 18px rgba(0, 255, 120, 0.25);
        backdrop-filter: blur(3px);
        color: #eafff2;
        opacity: 0;
        transform: translateY(-10px);
        transition: opacity 0.32s ease, transform 0.32s ease;
      }
      .badge-toast.is-in { opacity: 1; transform: translateY(0); }
      .badge-toast.is-out { opacity: 0; transform: translateY(-10px); }
      .badge-toast-star {
        flex: none;
        font-size: 18px;
        line-height: 1;
        color: #eafff2;
        text-shadow: 0 0 10px rgba(0, 255, 120, 0.8);
      }
      .badge-toast-text {
        display: flex;
        flex-direction: column;
        gap: 1px;
        min-width: 0;
      }
      .badge-toast-eyebrow {
        font-size: 8px;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: #7fe0aa;
        opacity: 0.8;
      }
      .badge-toast-name {
        font-size: 12px;
        font-weight: 700;
        color: #d9ffec;
        text-shadow: 0 0 8px rgba(0, 255, 120, 0.4);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
      }
      .badge-toast-detail {
        font-size: 10px;
        color: #9fe0bd;
        opacity: 0.85;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
      }
      @media (prefers-reduced-motion: reduce) {
        .badge-toast,
        .badge-toast.is-in,
        .badge-toast.is-out { transform: none; }
      }

      /* ---- Session stats ------------------------------------------------- */
      .stats-body {
        display: flex;
        flex-direction: column;
        gap: 18px;
        padding: 14px;
      }
      .session-section {
        display: flex;
        flex-direction: column;
        gap: 10px;
      }
      .session-section-title {
        margin: 0;
        font-size: 12px;
        font-weight: 700;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: #baffd7;
        text-shadow: 0 0 8px rgba(0, 255, 120, 0.4);
      }
      .session-hero {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
        gap: 10px;
      }
      .session-rows {
        display: flex;
        flex-direction: column;
        border: 1px solid rgba(0, 255, 120, 0.2);
        border-radius: 8px;
        overflow: hidden;
        background: rgba(0, 40, 18, 0.25);
      }
      .session-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 12px;
        padding: 10px 14px;
        border-top: 1px solid rgba(0, 255, 120, 0.12);
      }
      .session-row:first-child { border-top: none; }
      .session-row-label {
        font-size: 11px;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        opacity: 0.65;
        color: #9fe0bd;
      }
      .session-row-value {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 13px;
        font-weight: 700;
        color: #d9ffec;
        text-align: right;
      }
      .session-tag {
        font-size: 9px;
        font-weight: 700;
        letter-spacing: 0.08em;
        padding: 2px 6px;
        border-radius: 999px;
        border: 1px solid currentColor;
      }
      .session-tag-rare { color: #ffe08a; }
      .session-tag-mil { color: #8ac6ff; }
      .session-tag-emergency { color: #ff8a8a; }
      .session-badges {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
        gap: 10px;
      }
      .badge-when {
        font-size: 10px;
        opacity: 0.75;
        color: #9fe0bd;
      }
      .session-empty {
        padding: 24px 14px;
        text-align: center;
        font-size: 12px;
        line-height: 1.5;
        color: #9fe0bd;
        opacity: 0.7;
      }
