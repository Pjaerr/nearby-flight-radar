---
// Fully static page. All flight logic runs client-side against two keyless,
// CORS-enabled public APIs (airplanes.live + adsbdb.com). No backend.
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="Live green radar of aircraft flying near you." />
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/favicon.svg`} />
    <title>Nearby Flight Radar</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Share+Tech+Mono&display=swap"
    />
  </head>
  <body>
    <div class="corner-controls corner-left">
      <button
        id="passport-btn"
        type="button"
        class="fs-btn passport-btn"
        title="Flight passport"
        aria-label="Open flight passport"
        aria-haspopup="dialog"
      >
        <svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true" focusable="false">
          <circle cx="12" cy="12" r="9" fill="none" stroke="currentColor" stroke-width="2" />
          <ellipse cx="12" cy="12" rx="4" ry="9" fill="none" stroke="currentColor" stroke-width="2" />
          <path d="M3.5 9h17M3.5 15h17" fill="none" stroke="currentColor" stroke-width="2" />
        </svg>
        <span class="passport-btn-label">Passport</span>
      </button>

      <button
        id="dev-toggle"
        type="button"
        class="fs-btn dev-toggle"
        title="Dev toolbox"
        aria-label="Open dev toolbox"
        aria-haspopup="dialog"
      >
        <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" focusable="false">
          <path
            d="M9 8l-4 4 4 4M15 8l4 4-4 4"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          />
        </svg>
      </button>
    </div>

    <button
      id="sound-btn"
      type="button"
      class="fs-btn sound-btn"
      title="Enable sound"
      aria-label="Toggle sound"
      aria-pressed="false"
    >
      <svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true" focusable="false">
        <path
          d="M4 9v6h4l5 4V5L8 9H4z"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linejoin="round"
        />
        <path
          class="snd-icon-on"
          d="M16 8.5a5 5 0 0 1 0 7M18.5 6a8 8 0 0 1 0 12"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
        />
        <path
          class="snd-icon-off"
          d="M16 9l5 6M21 9l-5 6"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
        />
      </svg>
    </button>

    <button
      id="fullscreen-btn"
      type="button"
      class="fs-btn"
      title="Fullscreen"
      aria-label="Toggle fullscreen"
      aria-pressed="false"
    >
      <svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true" focusable="false">
        <path
          class="fs-icon-expand"
          d="M4 9V4h5M20 9V4h-5M4 15v5h5M20 15v5h-5"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        />
        <path
          class="fs-icon-collapse"
          d="M9 4v5H4M15 4v5h5M9 20v-5H4M15 20v-5h5"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        />
      </svg>
    </button>

    <main class="app">
      <header class="hud">
        <h1>NEARBY FLIGHT RADAR</h1>
        <dl class="readout">
          <div>
            <dt>CENTER</dt>
            <dd class="range-cell">
              <span id="stat-location">&mdash;</span>
              <button id="center-edit" type="button" class="range-edit" aria-haspopup="dialog">Set</button>
            </dd>
          </div>
          <div>
            <dt>RANGE</dt>
            <dd class="range-cell">
              <span id="stat-range">&mdash;</span>
              <button id="range-edit" type="button" class="range-edit" aria-haspopup="dialog">Adjust</button>
            </dd>
          </div>
        </dl>
      </header>

      <section class="scope">
        <div class="crt-wrap">
          <div class="crt">
            <canvas
              id="radar"
              width="720"
              height="720"
              role="img"
              aria-label="Flight radar scope. A text list of the aircraft currently detected follows below."
            ></canvas>
            <div class="crt-roll" aria-hidden="true"></div>
          </div>
          <!-- Info cards render here, above the circular CRT mask and its
               scanline/glare overlays, so they are never clipped or dimmed. -->
          <canvas id="radar-labels" class="label-layer" width="720" height="720" aria-hidden="true"></canvas>
        </div>
      </section>

      <!-- Dev / demo panel. Hidden unless the page is loaded with ?dev in the
           URL (or the D key is pressed). Injects synthetic contacts so the
           banner and highlighting can be previewed with no real traffic.
           Wired up in main.js. -->
      <div id="dev-panel" class="dev-panel" hidden>
        <div class="dev-head">
          <span>DEV / DEMO</span>
          <button id="dev-close" type="button" class="icon-btn" aria-label="Hide dev panel">&times;</button>
        </div>
        <div class="dev-buttons">
          <button type="button" data-demo="heavy">Heavy jet</button>
          <button type="button" data-demo="rare">Rare (A380)</button>
          <button type="button" data-demo="military">Military</button>
          <button type="button" data-demo="emergency">Emergency 7700</button>
          <button type="button" data-demo="radio">Radio fail 7600</button>
          <button type="button" data-demo="hijack">Hijack 7500</button>
          <button type="button" data-demo="light">Light GA</button>
        </div>
        <div class="dev-buttons">
          <button type="button" data-demo-action="clear">Clear demo</button>
        </div>
        <p class="dev-hint">Open with <code>?dev</code> or toggle with <kbd>D</kbd>.</p>
      </div>

      <footer class="hud">
        <p id="status" data-kind="info" role="status" aria-live="polite">Initializing&hellip;</p>
        <p class="credit">
          Positions: airplanes.live &middot; Routes: adsbdb.com &middot; Map: OpenStreetMap &middot; Non-commercial use
        </p>
      </footer>

      <!-- Screen-reader accessibility. The radar is drawn on a <canvas>, which is
           opaque to assistive tech, so these regions provide an equivalent text
           experience: `sr-live` is a polite log that announces each aircraft the
           moment it appears on the scope, and `sr-aircraft` is a navigable list
           that always mirrors the contacts currently being tracked. Both are
           visually hidden but exposed to screen readers. -->
      <div id="sr-live" class="sr-only" role="log" aria-live="polite" aria-atomic="false"></div>
      <section id="sr-aircraft" class="sr-only" aria-labelledby="sr-aircraft-heading">
        <h2 id="sr-aircraft-heading">Aircraft on radar</h2>
        <p id="sr-aircraft-empty">No aircraft on the radar right now.</p>
        <ul id="sr-aircraft-list"></ul>
      </section>
    </main>

    <div id="range-modal" class="modal" role="dialog" aria-modal="true" aria-label="Set radar range" hidden>
      <div class="modal-card">
        <div class="modal-head">
          <span>SET RADAR RANGE</span>
          <button id="range-close" type="button" class="icon-btn" aria-label="Close">&times;</button>
        </div>
        <div id="range-map" class="map"></div>
        <div class="modal-controls">
          <input id="range-slider" type="range" min="1" max="50" step="1" value="5" aria-label="Radius in nautical miles" />
          <output id="range-value">5 nm</output>
          <button id="range-apply" type="button" class="range-apply">Apply</button>
        </div>
        <p class="modal-hint">Drag the slider or click the map to set your radius.</p>
      </div>
    </div>

    <div id="center-modal" class="modal" role="dialog" aria-modal="true" aria-label="Set your location" hidden>
      <div class="modal-card">
        <div class="modal-head">
          <span>SET LOCATION</span>
          <button id="center-close" type="button" class="icon-btn" aria-label="Close">&times;</button>
        </div>
        <div id="center-map" class="map"></div>
        <div class="modal-controls">
          <input
            id="center-search"
            type="text"
            class="center-search"
            placeholder="Search a place, or enter lat, lon"
            aria-label="Search for a location"
            autocomplete="off"
          />
          <button id="center-search-btn" type="button" class="range-apply">Search</button>
        </div>
        <div class="modal-controls">
          <button id="center-geo" type="button" class="geo-btn">
            <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" focusable="false">
              <circle cx="12" cy="12" r="4" fill="none" stroke="currentColor" stroke-width="2" />
              <circle cx="12" cy="12" r="1.5" fill="currentColor" />
              <path
                d="M12 2v3M12 19v3M2 12h3M19 12h3"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
              />
            </svg>
            <span>Use my location</span>
          </button>
        </div>
        <div class="modal-controls">
          <output id="center-value">&mdash;</output>
          <button id="center-apply" type="button" class="range-apply">Apply</button>
        </div>
        <p id="center-hint" class="modal-hint">Search, or click the map to set your center.</p>
      </div>
    </div>

    <div id="passport-modal" class="modal" role="dialog" aria-modal="true" aria-label="Flight passport" hidden>
      <div class="modal-card passport-card">
        <div class="modal-head">
          <span>FLIGHT PASSPORT</span>
          <button id="passport-close" type="button" class="icon-btn" aria-label="Close">&times;</button>
        </div>
        <div class="passport-crt">
          <div id="passport-map" class="map passport-map"></div>
        </div>
        <div class="passport-stats">
          <output id="passport-count">0 / 195 countries</output>
          <button id="passport-reset" type="button" class="passport-reset">Reset</button>
        </div>
        <div id="passport-list" class="passport-list"></div>
        <p class="modal-hint">Countries light up when a flight to or from there crosses your radar.</p>
      </div>
    </div>

    <script>
      import '../scripts/main.js';
    </script>

    <style is:global>
      :root {
        --green: #00ff78;
        --green-dim: rgba(0, 255, 120, 0.55);
        --bg: #020a05;
      }
      * { box-sizing: border-box; }
      /* Visually hidden but available to screen readers (the standard clip
         pattern). Used for the live announcements and the text aircraft list. */
      .sr-only {
        position: absolute;
        width: 1px;
        height: 1px;
        padding: 0;
        margin: -1px;
        overflow: hidden;
        clip: rect(0, 0, 0, 0);
        white-space: nowrap;
        border: 0;
      }
      html, body {
        margin: 0;
        height: 100%;
        background: radial-gradient(circle at 50% 40%, #04170c 0%, var(--bg) 70%);
        color: var(--green);
        font-family: 'Share Tech Mono', ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
      }
      .app {
        min-height: 100%;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 12px;
        padding: 16px;
      }
      .hud { width: 100%; max-width: 760px; }
      h1 {
        font-size: clamp(14px, 3.5vw, 22px);
        letter-spacing: 0.25em;
        margin: 0 0 10px;
        text-shadow: 0 0 12px rgba(0, 255, 120, 0.6);
      }
      .readout {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 8px;
        margin: 0;
      }
      .readout > div {
        border: 1px solid rgba(0, 255, 120, 0.25);
        border-radius: 6px;
        padding: 6px 10px;
        background: rgba(0, 40, 18, 0.35);
      }
      dt {
        font-size: 10px;
        letter-spacing: 0.15em;
        opacity: 0.65;
      }
      dd {
        margin: 2px 0 0;
        font-size: 14px;
        font-weight: 700;
        color: #baffd7;
        text-shadow: 0 0 8px rgba(0, 255, 120, 0.5);
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
      }
      .scope {
        flex: 1;
        width: 100%;
        max-width: 760px;
        display: flex;
        align-items: center;
        justify-content: center;
      }
      /* Positioning context that holds the round CRT plus the flat, unclipped
         label layer stacked on top of it. Shrinks to fit the CRT. */
      .crt-wrap {
        position: relative;
        display: inline-flex;
        width: min(88vw, 72vh, 720px);
        aspect-ratio: 1 / 1;
      }
      /* Circular outer halo drawn behind the (masked) tube, so the green glow
         keeps its round shape after the mask on .crt clips its own box-shadow. */
      .crt-wrap::before {
        content: '';
        position: absolute;
        inset: 0;
        z-index: -1;
        border-radius: 50%;
        pointer-events: none;
        box-shadow: 0 0 40px rgba(0, 255, 120, 0.25);
      }
      /* CRT enclosure: holds the radar canvas plus the scanline/glare overlays
         that give it the look of a curved phosphor tube. */
      .crt {
        position: relative;
        width: 100%;
        height: 100%;
        border-radius: 50%;
        overflow: hidden;
        isolation: isolate;
        /* Safari/WebKit ignores `overflow: hidden` + `border-radius` for
           children promoted to their own compositing layer (transform,
           backface-visibility, mix-blend-mode, animation), letting the rolling
           bar and scanline overlays leak into the square's corners. A circular
           mask forces the clip to be applied after compositing, so composited
           descendants stay inside the tube on every browser. */
        -webkit-mask-image: radial-gradient(circle closest-side at 50% 50%, #000 99.5%, transparent 100%);
        mask-image: radial-gradient(circle closest-side at 50% 50%, #000 99.5%, transparent 100%);
        /* Only the inset glow lives here; the mask above would clip an outer
           box-shadow. The outer halo is drawn by .crt-wrap::before instead. */
        box-shadow: inset 0 0 60px rgba(0, 255, 120, 0.08);
      }
      /* Info-card layer: same coordinate space as the radar canvas but placed
         above the circular clip and every CRT overlay, so cards are drawn in
         full and on top of all other elements. */
      .label-layer {
        position: absolute;
        inset: 0;
        z-index: 10;
        width: 100%;
        height: 100%;
        pointer-events: none;
      }
      #radar {
        display: block;
        width: 100%;
        height: 100%;
        border-radius: 50%;
        /* Faint horizontal smear mimics phosphor bleed between scanlines. */
        filter: saturate(1.1) contrast(1.05);
        /* The tube "flicker" lives on the canvas rather than on .crt so the
           parent that hosts the overlays never becomes an animating opacity
           group, which on several mobile GPUs drops the overlays over part of
           the circle. */
        animation: crt-flicker 5s infinite;
      }
      /* Static scanlines drawn over the whole tube. These deliberately avoid
         mix-blend-mode and GPU layer promotion (translateZ/backface-visibility):
         blending against the tube on some mobile/tablet GPUs only paints part
         of the circle (e.g. a single corner). Over this near-black backdrop a
         plain translucent overlay is visually indistinguishable from multiply
         but is painted in the normal raster, so it always fills the circle. */
      .crt::before {
        content: '';
        position: absolute;
        inset: 0;
        z-index: 2;
        border-radius: 50%;
        pointer-events: none;
        background: repeating-linear-gradient(
          to bottom,
          rgba(0, 0, 0, 0) 0,
          rgba(0, 0, 0, 0) 2px,
          rgba(0, 20, 8, 0.4) 3px,
          rgba(0, 20, 8, 0.4) 4px
        );
      }
      /* Curved-glass vignette plus a soft top glare highlight. */
      .crt::after {
        content: '';
        position: absolute;
        inset: 0;
        z-index: 3;
        border-radius: 50%;
        pointer-events: none;
        background:
          radial-gradient(ellipse 60% 40% at 50% 16%, rgba(200, 255, 220, 0.08), rgba(200, 255, 220, 0) 60%),
          radial-gradient(circle at 50% 50%, rgba(0, 0, 0, 0) 52%, rgba(0, 10, 4, 0.65) 100%);
      }
      /* Rolling refresh bar that drifts down the tube like a real CRT. Uses
         plain alpha (no screen blend) for the same cross-GPU reason as above. */
      .crt-roll {
        position: absolute;
        left: 0;
        right: 0;
        top: -25%;
        height: 25%;
        z-index: 2;
        pointer-events: none;
        background: linear-gradient(
          to bottom,
          rgba(140, 255, 190, 0) 0%,
          rgba(140, 255, 190, 0.09) 50%,
          rgba(140, 255, 190, 0) 100%
        );
        animation: crt-roll 7s linear infinite;
      }
      @keyframes crt-roll {
        0% { transform: translateY(0); }
        100% { transform: translateY(500%); }
      }
      @keyframes crt-flicker {
        0%, 100% { opacity: 1; }
        7% { opacity: 0.94; }
        9% { opacity: 1; }
        41% { opacity: 0.98; }
        43% { opacity: 0.9; }
        45% { opacity: 1; }
        78% { opacity: 0.96; }
      }
      @media (prefers-reduced-motion: reduce) {
        #radar { animation: none; }
        .crt-roll { display: none; }
      }
      footer.hud { text-align: center; }
      #status {
        margin: 0;
        font-size: 13px;
        min-height: 1.2em;
      }
      #status[data-kind='ok'] { color: #9dffc4; }
      #status[data-kind='warn'] { color: #ffe37a; }
      #status[data-kind='error'] { color: #ff8a8a; }
      .credit {
        margin: 6px 0 0;
        font-size: 10px;
        opacity: 0.5;
        letter-spacing: 0.08em;
      }

      .fs-btn {
        position: fixed;
        top: 14px;
        right: 14px;
        z-index: 500;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--green);
        background: rgba(0, 40, 18, 0.5);
        border: 1px solid rgba(0, 255, 120, 0.4);
        border-radius: 8px;
        padding: 8px;
        cursor: pointer;
        opacity: 0.55;
        transition: opacity 0.15s ease, background 0.15s ease;
      }
      .fs-btn:hover {
        opacity: 1;
        background: rgba(0, 255, 120, 0.2);
      }
      .fs-icon-collapse { display: none; }

      /* Groups the top-left buttons so they sit side by side regardless of the
         passport label's width. Its children opt out of the fixed positioning
         the .fs-btn base rule sets. */
      .corner-controls {
        position: fixed;
        top: 14px;
        z-index: 500;
        display: flex;
        align-items: stretch;
        gap: 8px;
      }
      .corner-left { left: 14px; }
      .corner-controls .fs-btn {
        position: static;
        top: auto;
        left: auto;
        right: auto;
      }

      .passport-btn {
        gap: 8px;
        padding: 8px 12px;
      }
      /* Deliberately faint so it stays out of the way until you look for it. */
      .dev-toggle { opacity: 0.32; }
      .passport-btn-label {
        font-size: 12px;
        letter-spacing: 0.12em;
        text-transform: uppercase;
      }

      /* Sound toggle sits just left of the fullscreen button (top-right). */
      .sound-btn { right: 60px; }
      /* Show the muted (crossed-out) glyph until sound is enabled. */
      .snd-icon-off { display: none; }
      .sound-btn[aria-pressed='false'] .snd-icon-on { display: none; }
      .sound-btn[aria-pressed='false'] .snd-icon-off { display: block; }
      .sound-btn[aria-pressed='true'] { opacity: 0.9; color: #baffd7; }

      /* ---- Dev / demo panel ----------------------------------------------- */
      .dev-panel[hidden] { display: none; }
      .dev-panel {
        position: fixed;
        left: 14px;
        bottom: 14px;
        z-index: 700;
        width: 220px;
        padding: 10px 12px 12px;
        background: rgba(4, 20, 11, 0.92);
        border: 1px solid rgba(0, 255, 120, 0.4);
        border-radius: 10px;
        box-shadow: 0 0 30px rgba(0, 255, 120, 0.2);
        backdrop-filter: blur(3px);
      }
      .dev-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        font-size: 11px;
        letter-spacing: 0.2em;
        opacity: 0.85;
        margin-bottom: 8px;
      }
      .dev-buttons {
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
        margin-bottom: 6px;
      }
      .dev-buttons button {
        font: inherit;
        font-size: 11px;
        letter-spacing: 0.04em;
        color: var(--green);
        background: rgba(0, 255, 120, 0.1);
        border: 1px solid rgba(0, 255, 120, 0.35);
        border-radius: 5px;
        padding: 5px 8px;
        cursor: pointer;
        transition: background 0.15s ease;
      }
      .dev-buttons button:hover { background: rgba(0, 255, 120, 0.25); }
      .dev-hint {
        margin: 4px 0 0;
        font-size: 10px;
        opacity: 0.5;
      }
      .dev-hint kbd,
      .dev-hint code {
        color: #baffd7;
        background: rgba(0, 255, 120, 0.12);
        border-radius: 3px;
        padding: 0 4px;
      }

      /* Immersive wall mode: radar edge to edge, HUD boxes hidden. */
      body.immersive .app {
        padding: 0;
        gap: 0;
        justify-content: center;
      }
      body.immersive .hud { display: none; }
      body.immersive .scope { max-width: none; }
      body.immersive .crt-wrap {
        width: min(90vw, 90vh);
        max-width: none;
      }
      body.immersive .fs-icon-expand { display: none; }
      body.immersive .fs-icon-collapse { display: block; }

      /* On narrow / portrait screens there isn't enough horizontal room for the
         HUD title to sit between the fixed corner buttons (passport on the left,
         sound + fullscreen on the right), so they overlap. Drop the header below
         the top button row by reserving vertical space. The immersive rule above
         still wins (higher specificity) and keeps its padding: 0. */
      @media (max-width: 900px) {
        .app { padding-top: 64px; }
      }

      .range-cell {
        display: flex;
        align-items: center;
        gap: 8px;
      }
      .range-edit {
        font: inherit;
        font-size: 10px;
        letter-spacing: 0.1em;
        color: var(--green);
        background: rgba(0, 255, 120, 0.1);
        border: 1px solid rgba(0, 255, 120, 0.4);
        border-radius: 4px;
        padding: 2px 8px;
        cursor: pointer;
        transition: background 0.15s ease;
      }
      .range-edit:hover {
        background: rgba(0, 255, 120, 0.25);
      }

      .modal[hidden] { display: none; }
      .modal {
        position: fixed;
        inset: 0;
        z-index: 1000;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 16px;
        background: rgba(2, 10, 5, 0.75);
        backdrop-filter: blur(3px);
      }
      .modal-card {
        width: 100%;
        max-width: 560px;
        background: #041a0d;
        border: 1px solid rgba(0, 255, 120, 0.35);
        border-radius: 10px;
        box-shadow: 0 0 40px rgba(0, 255, 120, 0.25);
        overflow: hidden;
      }
      .modal-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 12px 14px;
        font-size: 12px;
        letter-spacing: 0.15em;
        border-bottom: 1px solid rgba(0, 255, 120, 0.2);
      }
      .icon-btn {
