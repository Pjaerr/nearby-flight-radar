      .passport-card { max-width: 720px; }
      /* CRT enclosure for the world map: same scanline/glare/vignette treatment
         as the round radar tube, but rectangular. The map sits at the bottom of
         the stack; the overlays below are painted on top and ignore pointer
         events so panning/zooming still works. */
      .passport-crt {
        position: relative;
        overflow: hidden;
        isolation: isolate;
        border-bottom: 1px solid rgba(0, 255, 120, 0.2);
      }
      .passport-map {
        height: 380px;
        /* Ocean is black; the seamless land layer paints continents black with
           a green coastline, so the map reads as green outlines on a dark tube
           with visited countries filled green. */
        background: #000000;
      }
      /* Leaflet paints a light grey backdrop by default; keep the tube dark. */
      .passport-map :global(.leaflet-container) {
        background: transparent;
        font-family: 'Share Tech Mono', ui-monospace, SFMono-Regular, Menlo, monospace;
      }
      /* A faint green bloom on the outlines so visited countries glow softly
         without overpowering the map. */
      .passport-map :global(.leaflet-overlay-pane) {
        filter: drop-shadow(0 0 1px rgba(0, 255, 120, 0.35));
      }
      /* Tint Leaflet's tooltips to match the HUD instead of the default white. */
      .passport-map :global(.leaflet-tooltip) {
        background: rgba(4, 26, 13, 0.92);
        border: 1px solid rgba(0, 255, 120, 0.4);
        border-radius: 4px;
        color: #baffd7;
        font-size: 11px;
        letter-spacing: 0.04em;
        box-shadow: 0 0 10px rgba(0, 255, 120, 0.25);
      }
      .passport-map :global(.leaflet-tooltip-top::before),
      .passport-map :global(.leaflet-tooltip-bottom::before),
      .passport-map :global(.leaflet-tooltip-left::before),
      .passport-map :global(.leaflet-tooltip-right::before) {
        display: none;
      }
      /* Restyle the zoom control as a HUD element rather than the light default. */
      .passport-map :global(.leaflet-control-zoom a) {
        background: rgba(4, 26, 13, 0.9);
        border: 1px solid rgba(0, 255, 120, 0.35);
        color: var(--green);
        text-shadow: 0 0 6px rgba(0, 255, 120, 0.5);
      }
      .passport-map :global(.leaflet-control-zoom a:hover) {
        background: rgba(0, 255, 120, 0.2);
      }
      /* Very faint static scanlines for a hint of CRT texture. */
      .passport-crt::before {
        content: '';
        position: absolute;
        inset: 0;
        z-index: 400;
        pointer-events: none;
        background: repeating-linear-gradient(
          to bottom,
          rgba(0, 0, 0, 0) 0,
          rgba(0, 0, 0, 0) 3px,
          rgba(0, 20, 8, 0.14) 4px
        );
        mix-blend-mode: multiply;
      }
      /* Subtle edge vignette so the corners fall off gently. */
      .passport-crt::after {
        content: '';
        position: absolute;
        inset: 0;
        z-index: 401;
        pointer-events: none;
        background: radial-gradient(
          ellipse 100% 100% at 50% 50%,
          rgba(0, 0, 0, 0) 70%,
          rgba(0, 10, 4, 0.35) 100%
        );
      }
      .passport-stats {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        padding: 12px 14px 6px;
      }
      #passport-count {
        font-weight: 700;
        font-size: 14px;
        color: #baffd7;
        text-shadow: 0 0 8px rgba(0, 255, 120, 0.5);
      }
      .passport-reset {
        font: inherit;
        font-size: 10px;
        letter-spacing: 0.1em;
        color: var(--green);
        background: rgba(0, 255, 120, 0.1);
        border: 1px solid rgba(0, 255, 120, 0.4);
        border-radius: 4px;
        padding: 3px 10px;
        cursor: pointer;
        transition: background 0.15s ease;
      }
      .passport-reset:hover { background: rgba(0, 255, 120, 0.25); }
      .passport-list {
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
        max-height: 96px;
        overflow-y: auto;
        padding: 6px 14px 4px;
      }
      .passport-chip {
        font-size: 11px;
        color: #baffd7;
        background: rgba(0, 255, 120, 0.1);
        border: 1px solid rgba(0, 255, 120, 0.3);
        border-radius: 12px;
        padding: 2px 9px;
        white-space: nowrap;
      }
      .passport-empty {
        margin: 0;
        font-size: 12px;
        opacity: 0.55;
      }
    </style>
  </body>
